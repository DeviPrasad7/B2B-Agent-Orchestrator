# ──────────────────────────────────────────────────────────────────────────
# ICP Agent Platform – Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Database (required) ─────────────────────────────────────────────────
# For local Docker Compose setup:
DATABASE_URL=postgresql://agent:agent@localhost:5432/agentic

# ── LLM Provider (required) ─────────────────────────────────────────────
# Supported: openai, gemini, groq
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here

# ── Optional Service Keys ───────────────────────────────────────────────
# SCRAPER_API_KEY=
# ENRICHMENT_API_KEY=
# NEWS_API_KEY=

# ── Operational Tunables ─────────────────────────────────────────────────
# MAX_RETRIES=3
# HITL_TIMEOUT_SECONDS=86400
